APP_ENV=production
TIME_ZONE=Asia/Dhaka
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
LOG_LEVEL=INFO

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/bangla_library
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
PROCESSING_CHECKPOINT_REDIS_URL=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_PROCESSING_CONCURRENCY=3
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=500
GUNICORN_MAX_REQUESTS_JITTER=50
# Docker per-container memory limits.
BACKEND_MEM_LIMIT=700m
WORKER_MEM_LIMIT=600m
PROCESSING_WORKER_MEM_LIMIT=900m

PUBLIC_BASE_URL=https://example.com
PUBLIC_API_ORIGIN=https://example.com
FRONTEND_BASE_URL=https://example.com
PASSWORD_CREATE_FRONTEND_PATH=/create-password
PASSWORD_RESET_FRONTEND_PATH=/reset-password/confirm
VITE_API_BASE_URL=/api
RUNTIME_STORAGE_DIR=/app/storage

DEFAULT_FROM_EMAIL=
EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
ACCOUNT_INVITE_FROM_EMAIL=
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=a5e2f4001@smtp-brevo.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

BACKEND_PORT=8000
FRONTEND_PORT=4173
