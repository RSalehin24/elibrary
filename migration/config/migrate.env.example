# Most migration values are reused automatically from deploy/env/.host.env.
# The application will be restored in the same folder path and repo structure
# on the new server as well.
# Keep this file to the values that normally change for the new server.
# If you need an uncommon override like TARGET_USER, TARGET_REMOTE_APP_DIR,
# SOURCE_PORT, TARGET_PORT, or custom auth overrides, you can add them manually.

# New server details
TARGET_HOST=
TARGET_IP=

# Optional target env overrides
# Leave these blank when the domain and public URLs stay the same.
TARGET_PUBLIC_BASE_URL=
TARGET_PUBLIC_API_ORIGIN=
TARGET_FRONTEND_BASE_URL=
