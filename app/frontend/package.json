{
  "name": "bangla-library-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test:unit": "node --test ../../tests/frontend/unit/*.test.js",
    "test:e2e": "playwright test --config ../../tests/frontend/playwright.config.js",
    "test:e2e:headed": "playwright test --config ../../tests/frontend/playwright.config.js --headed",
    "test:e2e:existing-server": "PLAYWRIGHT_SKIP_STACK_START=1 playwright test --config ../../tests/frontend/playwright.config.js"
  },
  "dependencies": {
    "dompurify": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "playwright": "^1.53.0",
    "vite": "^5.4.19"
  }
}
