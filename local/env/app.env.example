APP_ENV=development
TIME_ZONE=Asia/Dhaka
DJANGO_SECRET_KEY=
DJANGO_DEBUG=1
LOG_LEVEL=INFO

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/bangla_library
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=0
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=1
GUNICORN_WORKERS=1
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=200
GUNICORN_MAX_REQUESTS_JITTER=20

PUBLIC_BASE_URL=http://127.0.0.1:8000
PUBLIC_API_ORIGIN=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:5173
PASSWORD_CREATE_FRONTEND_PATH=/create-password
PASSWORD_RESET_FRONTEND_PATH=/reset-password/confirm
VITE_API_BASE_URL=/api
RUNTIME_STORAGE_DIR=/app/storage

DEFAULT_FROM_EMAIL=
KINDLE_DELIVERY_FROM_EMAIL=
EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
ACCOUNT_INVITE_FROM_EMAIL=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

BACKEND_PORT=8000
FRONTEND_PORT=5173
